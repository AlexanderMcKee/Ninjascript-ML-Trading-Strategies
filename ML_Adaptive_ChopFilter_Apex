#region Using declarations
using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.ComponentModel.DataAnnotations;
using System.Linq;
using NinjaTrader.Cbi;
using NinjaTrader.Gui;
using NinjaTrader.NinjaScript;
using NinjaTrader.NinjaScript.Indicators;
#endregion

namespace NinjaTrader.NinjaScript.Strategies
{
	public class ML_Shredder_AutoPilot_Fixed : Strategy
	{
		private ATR atr;
		private double ST;
		private int direction = 1;
		private List<double> volHistory = new List<double>();
		
		protected override void OnStateChange()
		{
			if (State == State.SetDefaults)
			{
				Description					= "ML Shredder - Auto-Pilot with Apex Time Sentry (Fixed)";
				Name						= "ML_Shredder_AutoPilot_Fixed";
				Calculate					= Calculate.OnBarClose;
				EntriesPerDirection			= 1;
				
				// --- Core Settings ---
				AtrLen						= 10;
				Factor						= 2.5;
				TrainingPeriod				= 100;
				LockInVal					= 45.0;  
				TrailMult					= 1.4;
				UseChopFilter				= true;

				// --- Session Times (Pacific Time) ---
				StartTime					= new TimeSpan(15, 0, 10); // 3:00:10 PM PT
				EndTime						= new TimeSpan(12, 59, 0); // 12:59:00 PM PT
			}
			else if (State == State.DataLoaded)
			{
				atr = ATR(AtrLen);
			}
		}

		protected override void OnBarUpdate()
		{
			if (CurrentBar < TrainingPeriod) return;

			// --- 1. Apex Time Check ---
			TimeSpan now = Time[0].TimeOfDay;
			bool isAllowedToTrade = (now >= StartTime || now <= EndTime);

			if (!isAllowedToTrade && Position.MarketPosition != MarketPosition.Flat)
			{
				ExitLong("Apex Hard Close", "");
				ExitShort("Apex Hard Close", "");
				return;
			}

			// --- 2. ML Volatility Clustering ---
			double currentVol = atr[0];
			volHistory.Clear();
			for (int i = 0; i < TrainingPeriod; i++) volHistory.Add(atr[i]);

			double maxVol = volHistory.Max();
			double minVol = volHistory.Min();
			double aMean = minVol + (maxVol - minVol) * 0.75;
			double bMean = minVol + (maxVol - minVol) * 0.50;
			double cMean = minVol + (maxVol - minVol) * 0.25;

			double d1 = Math.Abs(currentVol - aMean);
			double d2 = Math.Abs(currentVol - bMean);
			double d3 = Math.Abs(currentVol - cMean);

			int bestCluster = (d2 < d1 && d2 < d3) ? 1 : (d3 < d1 && d3 < d2 ? 2 : 0);
			double assignedCentroid = (bestCluster == 1) ? bMean : (bestCluster == 2 ? cMean : aMean);

			// --- 3. SuperTrend Logic ---
			double midPrice = (High[0] + Low[0]) / 2;
			if (Close[0] > ST) direction = -1;
			else if (Close[0] < ST) direction = 1;
			ST = (direction == -1) ? midPrice - (Factor * assignedCentroid) : midPrice + (Factor * assignedCentroid);

			// --- 4. Execution ---
			bool bullSig = (Close[1] <= ST && Close[0] > ST);
			bool bearSig = (Close[1] >= ST && Close[0] < ST);
			bool volOk = !UseChopFilter || bestCluster != 2;

			if (isAllowedToTrade && volOk)
			{
				if (bullSig) EnterLong(1, "Long");
				if (bearSig) EnterShort(1, "Short");
			}

			// --- 5. Profit Guard ---
			if (Position.MarketPosition != MarketPosition.Flat)
			{
				double pnl = Position.GetUnrealizedProfitLoss(PerformanceUnit.Currency, Close[0]);
				if (pnl > LockInVal)
				{
					double trailAmt = ATR(14)[0] * TrailMult;
					if (Position.MarketPosition == MarketPosition.Long)
						ExitLongStopMarket(0, true, Position.Quantity, Close[0] - trailAmt, "Guard", "Long");
					else
						ExitShortStopMarket(0, true, Position.Quantity, Close[0] + trailAmt, "Guard", "Short");
				}
			}
		}

		#region Properties
		[NinjaScriptProperty]
		[Display(Name="ATR Length", GroupName="1. SuperTrend Settings")]
		public int AtrLen { get; set; }

		[NinjaScriptProperty]
		[Display(Name="Factor", GroupName="1. SuperTrend Settings")]
		public double Factor { get; set; }

		[NinjaScriptProperty]
		[Display(Name="Training Period", GroupName="2. ML Settings")]
		public int TrainingPeriod { get; set; }

		[NinjaScriptProperty]
		[Display(Name="Profit Guard Threshold ($)", GroupName="3. Risk")]
		public double LockInVal { get; set; }

		[NinjaScriptProperty]
		[Display(Name="Trail Multiplier", GroupName="3. Risk")]
		public double TrailMult { get; set; }

		[NinjaScriptProperty]
		[Display(Name="Use Chop Filter", GroupName="3. Risk")]
		public bool UseChopFilter { get; set; }

		[NinjaScriptProperty]
		[Display(Name="Apex Re-Open (PT)", GroupName="4. Session")]
		public TimeSpan StartTime { get; set; }

		[NinjaScriptProperty]
		[Display(Name="Apex Close (PT)", GroupName="4. Session")]
		public TimeSpan EndTime { get; set; }
		#endregion
	}
}
